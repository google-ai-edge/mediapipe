# Predicts left & right hand re-crop ROIs from body-pose landmarks using the
# learned HandRoiFromPoseNetCalculator (see calculators/), instead of the
# hand-coded heuristic. This graph shows how to wire the calculator: extract the
# six hand-related pose keypoints per side (shoulder, elbow, wrist, thumb, index,
# pinky) and run the net with the matching is_left option.
#
# To use it inside HolisticLandmark, replace the HandLandmarksFromPoseToRecropRoi
# node in hand_landmarks_left_and_right_cpu.pbtxt with these per-side splits +
# HandRoiFromPoseNetCalculator nodes. The existing 3-landmark visibility stream
# is unaffected.
#
# BlazePose pose-landmark indices used (order matters - must match the network's
# expected [shoulder, elbow, wrist, thumb, index, pinky]):
#   RIGHT: 12, 14, 16, 22, 20, 18      LEFT: 11, 13, 15, 21, 19, 17

type: "HandRoiFromPoseNetCpu"

input_stream: "IMAGE:input_video"
input_stream: "POSE_LANDMARKS:pose_landmarks"
output_stream: "LEFT_HAND_ROI_FROM_POSE:left_hand_roi_from_pose"
output_stream: "RIGHT_HAND_ROI_FROM_POSE:right_hand_roi_from_pose"

node {
  calculator: "ImagePropertiesCalculator"
  input_stream: "IMAGE:input_video"
  output_stream: "SIZE:image_size"
}

# ---------------- Right hand ----------------
node {
  calculator: "SplitNormalizedLandmarkListCalculator"
  input_stream: "pose_landmarks"
  output_stream: "right_hand6_from_pose"
  options: {
    [mediapipe.SplitVectorCalculatorOptions.ext] {
      ranges: { begin: 12 end: 13 }  # shoulder
      ranges: { begin: 14 end: 15 }  # elbow
      ranges: { begin: 16 end: 17 }  # wrist
      ranges: { begin: 22 end: 23 }  # thumb
      ranges: { begin: 20 end: 21 }  # index
      ranges: { begin: 18 end: 19 }  # pinky
      combine_outputs: true
    }
  }
}
node {
  calculator: "HandRoiFromPoseNetCalculator"
  input_stream: "LANDMARKS:right_hand6_from_pose"
  input_stream: "IMAGE_SIZE:image_size"
  output_stream: "ROI:right_hand_roi_from_pose"
  options: {
    [mediapipe.HandRoiFromPoseNetCalculatorOptions.ext] { is_left: false }
  }
}

# ---------------- Left hand ----------------
node {
  calculator: "SplitNormalizedLandmarkListCalculator"
  input_stream: "pose_landmarks"
  output_stream: "left_hand6_from_pose"
  options: {
    [mediapipe.SplitVectorCalculatorOptions.ext] {
      ranges: { begin: 11 end: 12 }  # shoulder
      ranges: { begin: 13 end: 14 }  # elbow
      ranges: { begin: 15 end: 16 }  # wrist
      ranges: { begin: 21 end: 22 }  # thumb
      ranges: { begin: 19 end: 20 }  # index
      ranges: { begin: 17 end: 18 }  # pinky
      combine_outputs: true
    }
  }
}
node {
  calculator: "HandRoiFromPoseNetCalculator"
  input_stream: "LANDMARKS:left_hand6_from_pose"
  input_stream: "IMAGE_SIZE:image_size"
  output_stream: "ROI:left_hand_roi_from_pose"
  options: {
    [mediapipe.HandRoiFromPoseNetCalculatorOptions.ext] { is_left: true }
  }
}
